{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"/home/aiuser/ai-trading-bot/.codex/hooks/aitmpl-codex--automation--agents-md-loader\" && ./.codex/hooks/automation-agents-md-loader-sessionstart-sessionstart-1-1.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"/home/aiuser/ai-trading-bot/.codex/hooks/aitmpl-codex--security--secret-scanner\" && ./.codex/hooks/security-secret-scanner-pretooluse-pretooluse-1-1.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"/home/aiuser/ai-trading-bot/.codex/hooks/aitmpl-codex--security--dangerous-command-blocker\" && ./.codex/hooks/security-dangerous-command-blocker-pretooluse-pretooluse-1-1.sh"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"/home/aiuser/ai-trading-bot/.codex/hooks/aitmpl-codex--development-tools--command-logger\" && ./.codex/hooks/development-tools-command-logger-pretooluse-pretooluse-1-1.sh"
