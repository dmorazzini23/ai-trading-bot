      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"/home/aiuser/ai-trading-bot/.codex/hooks/aitmpl-codex--automation--change-logger\" && ./.codex/hooks/automation-change-logger-posttooluse-posttooluse-4-1.sh"
