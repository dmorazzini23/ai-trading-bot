# Recommended production overlay (conservative rollout)
# Generated: 2026-04-09
#
# Apply on top of your existing `.env` (do not replace secrets).
# This keeps shorting enabled and uses explicit/runtime-authoritative toggles.

# Keep shorts enabled
TRADING_ALLOW_SHORTS=1

# Single source of truth for rollout toggles (legacy shorthand ignored)
AI_TRADING_EXEC_LEGACY_SHORT_KNOBS_ENABLED=0

# Runtime go/no-go: profit factor as secondary diagnostic by default
AI_TRADING_RUNTIME_GONOGO_REQUIRE_PROFIT_FACTOR_GATE=0
AI_TRADING_EXECUTION_RUNTIME_GONOGO_REQUIRE_PROFIT_FACTOR_GATE=0

# Missing critical submit context: hard block in live
AI_TRADING_EXECUTION_WARN_MISSING_SUBMIT_CONTEXT=1
AI_TRADING_EXECUTION_REQUIRE_SUBMIT_CONTEXT_LIVE=1

# Learned expected-capture model (fill probability + explicit execution cost)
AI_TRADING_EXEC_EXPECTED_CAPTURE_RANK_ENABLED=1
AI_TRADING_EXEC_EXPECTED_CAPTURE_RANK_WEIGHT=0.30
AI_TRADING_EXEC_EXPECTED_CAPTURE_FLOOR_BPS=-3.0
AI_TRADING_EXEC_EXPECTED_CAPTURE_FLOOR_ADAPTIVE_ENABLED=1
AI_TRADING_EXEC_EXPECTED_CAPTURE_FLOOR_ADAPTIVE_QUANTILE=0.20
AI_TRADING_EXEC_EXPECTED_CAPTURE_LEARNED_FILL_MODEL_ENABLED=1
AI_TRADING_EXEC_EXPECTED_CAPTURE_LEARNED_FILL_MIN_SAMPLES=30
AI_TRADING_EXEC_EXPECTED_CAPTURE_COST_MODEL_ENABLED=1
AI_TRADING_EXEC_EXPECTED_CAPTURE_COST_MODEL_MIN_SAMPLES=30
AI_TRADING_EXEC_EXPECTED_CAPTURE_COST_SPREAD_WEIGHT=1.0
AI_TRADING_EXEC_EXPECTED_CAPTURE_COST_IMPACT_WEIGHT=1.0
AI_TRADING_EXEC_EXPECTED_CAPTURE_COST_LATENCY_WEIGHT=1.0
AI_TRADING_EXEC_EXPECTED_CAPTURE_LATENCY_BPS_PER_SEC=0.02
AI_TRADING_EXEC_EXPECTED_CAPTURE_CONSTRAINT_WEIGHT=0.80
AI_TRADING_EXEC_EXPECTED_CAPTURE_CONSTRAINT_MAX_ADJUST_ABS=12.0

# Statistical promotion gating + unified marginal contribution watchdog
AI_TRADING_POLICY_ABLATION_ADAPTIVE_THRESHOLD_ENABLED=1
AI_TRADING_POLICY_ABLATION_ADAPTIVE_THRESHOLD_QUANTILE=0.35
AI_TRADING_POLICY_TOGGLE_SIGNIFICANCE_ENABLED=1
AI_TRADING_POLICY_TOGGLE_SIGNIFICANCE_METHOD=both
AI_TRADING_POLICY_TOGGLE_BAYES_POSTERIOR_MIN=0.92
AI_TRADING_POLICY_TOGGLE_SPRT_ALPHA=0.05
AI_TRADING_POLICY_TOGGLE_SPRT_BETA=0.10
AI_TRADING_POLICY_TOGGLE_SPRT_EFFECT_BPS=0.40
AI_TRADING_MARGINAL_CONTRIBUTION_WATCHDOG_ENABLED=1
AI_TRADING_MARGINAL_CONTRIBUTION_WATCHDOG_MIN_EVENTS=500
AI_TRADING_MARGINAL_CONTRIBUTION_WATCHDOG_MIN_RELATIVE_BPS=0.0

# Reduce stacked conservatism from parallel penalty layers
AI_TRADING_MULTI_PENALTY_COORDINATION_ENABLED=1
AI_TRADING_MULTI_PENALTY_COORDINATION_WEIGHT_DAMPEN=0.50
AI_TRADING_MULTI_PENALTY_COORDINATION_MIN_SCALE_FLOOR=0.55

# Controlled rollout knobs (explicit, conservative)
AI_TRADING_EXEC_BANDIT_ROUTING_ENABLED=1
AI_TRADING_EXEC_BANDIT_SCORE_WEIGHT=0.08
AI_TRADING_EXEC_BANDIT_MIN_SAMPLES=60
AI_TRADING_EXEC_BANDIT_SHADOW_ONLY=0
AI_TRADING_EXEC_GEOMETRIC_TIEBREAK_ENABLED=1
AI_TRADING_EXEC_GEOMETRIC_TIEBREAK_WEIGHT=0.08
AI_TRADING_EXECUTION_META_LABEL_GATE_ENABLED=1
AI_TRADING_EXECUTION_META_LABEL_REQUIRE_SCORE=0
AI_TRADING_EXECUTION_META_LABEL_MIN_SCORE=0.45
AI_TRADING_EXEC_PORTFOLIO_OPTIMIZER_ENABLED=1
AI_TRADING_EXEC_PORTFOLIO_OPTIMIZER_OPENINGS_ONLY=1
AI_TRADING_EXEC_PORTFOLIO_OPTIMIZER_IMPROVEMENT_THRESHOLD=0.08
AI_TRADING_EXEC_COUNTERFACTUAL_LEARNING_ENABLED=1
AI_TRADING_EXEC_COUNTERFACTUAL_SCORE_WEIGHT=0.08
AI_TRADING_EXEC_COUNTERFACTUAL_MIN_SAMPLES=60
AI_TRADING_EXEC_COUNTERFACTUAL_SHADOW_ONLY=0
AI_TRADING_EXEC_COUNTERFACTUAL_AUTO_PROMOTE=0
AI_TRADING_EXEC_PORTFOLIO_LOG_GROWTH_RANK_ENABLED=1
AI_TRADING_EXEC_PORTFOLIO_LOG_GROWTH_RANK_WEIGHT=0.08
