# ===== PATHS / ARTIFACTS =====
AI_TRADING_DATA_DIR=/var/lib/ai-trading-bot
# Ensure runtime artifacts remain writable by the service account after resets.
AI_TRADING_RUNTIME_OWNER=aiuser:aiuser
AI_TRADING_CACHE_DIR=/var/cache/ai-trading-bot
AI_TRADING_LOG_DIR=/var/log/ai-trading-bot
AI_TRADING_MODELS_DIR=/var/lib/ai-trading-bot/models
AI_TRADING_OUTPUT_DIR=/var/lib/ai-trading-bot/output
AI_TRADING_MODEL_PATH=/var/lib/ai-trading-bot/models/runtime/ml_latest.joblib
AI_TRADING_RL_MODEL_PATH=/var/lib/ai-trading-bot/models/runtime/rl_agent.zip
HALT_FLAG_PATH=halt.flag
AI_TRADING_MODEL_MODULE=
AI_TRADING_AFTER_HOURS_RUNTIME_MODEL_PATH=/var/lib/ai-trading-bot/models/runtime/ml_latest.joblib

# ===== STRATEGY / MODES =====
AI_TRADING_TRADING_MODE=balanced
STRATEGIES=momentum,cross_sectional_momentum,multi_factor_quality_value,pairs_stat_arb,pead_event,low_beta_defensive,time_series_momentum_overlay
